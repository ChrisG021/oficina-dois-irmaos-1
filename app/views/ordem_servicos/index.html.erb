<% content_for :title, "Ordens de Servico | Oficina Dois Irmaos" %>

<main class="page-shell">
  <section class="page-heading">
    <div>
      <p class="eyebrow">Atendimento</p>
      <h1>Ordens de servico</h1>
      <p>Controle os servicos abertos, em andamento e finalizados pela oficina.</p>
    </div>
    <div class="action-row">
      <%= link_to ordem_servicos_path(format: :pdf, status: params[:status]), class: "btn btn-outline-dark fw-bold" do %>
        <i class="bi bi-file-earmark-pdf"></i> PDF
      <% end %>
      <%= link_to new_ordem_servico_path, class: "btn btn-warning fw-bold" do %>
        <i class="bi bi-plus-circle"></i> Nova OS
      <% end %>
    </div>
  </section>

  <section class="data-panel">
    <div class="panel-header">
      <div>
        <h2>Lista de ordens</h2>
        <span class="muted-text"><%= @ordem_servicos.total_count %> registros encontrados</span>
      </div>
      <%= form_with url: ordem_servicos_path, method: :get, class: "d-flex gap-2", local: true do |form| %>
        <%= form.select :status, options_for_select([ [ "Todos", "" ] ] + OrdemServico::STATUS.map { |status| [ status, status ] }, params[:status]), {}, class: "form-select form-select-sm" %>
        <%= form.submit "Filtrar", class: "btn btn-sm btn-outline-secondary fw-bold" %>
      <% end %>
    </div>

    <% if @ordem_servicos.any? %>
      <div class="table-responsive">
        <table class="table table-hover align-middle">
          <thead>
            <tr>
              <th>OS</th>
              <th>Cliente</th>
              <th>Veiculo</th>
              <th>Status</th>
              <th>Entrada</th>
              <th class="text-end">Valor</th>
              <th class="text-end">Acoes</th>
            </tr>
          </thead>
          <tbody id="ordem_servicos">
            <%= render @ordem_servicos %>
          </tbody>
        </table>
      </div>
      <%= paginate @ordem_servicos %>
    <% else %>
      <div class="empty-state">
        <i class="bi bi-clipboard-plus"></i>
        <strong>Nenhuma ordem cadastrada</strong>
        <p class="mb-0">Abra uma ordem para registrar o atendimento de um veiculo.</p>
      </div>
    <% end %>
  </section>
</main>
