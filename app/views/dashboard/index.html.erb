<% content_for :title, "Painel | Oficina Dois Irmaos" %>

<main class="page-shell">
  <section class="page-heading">
    <div>
      <p class="eyebrow">Painel principal</p>
      <h1>Resumo da oficina</h1>
      <p>Acompanhe cadastros, veiculos e ordens de servico em um unico lugar.</p>
    </div>
    <div class="action-row">
      <%= link_to dashboard_csv_path(format: :csv), class: "btn btn-outline-dark fw-bold" do %>
        <i class="bi bi-filetype-csv"></i> Exportar CSV
      <% end %>
      <%= link_to new_ordem_servico_path, class: "btn btn-warning fw-bold" do %>
        <i class="bi bi-plus-circle"></i> Nova OS
      <% end %>
    </div>
  </section>

  <section class="metric-grid">
    <div class="metric-card">
      <i class="bi bi-people"></i>
      <span>Clientes</span>
      <strong><%= @clientes_count %></strong>
    </div>
    <div class="metric-card">
      <i class="bi bi-car-front"></i>
      <span>Veiculos</span>
      <strong><%= @veiculos_count %></strong>
    </div>
    <div class="metric-card">
      <i class="bi bi-clipboard2-check"></i>
      <span>Ordens</span>
      <strong><%= @ordens_count %></strong>
    </div>
    <div class="metric-card">
      <i class="bi bi-cash-coin"></i>
      <span>Total previsto</span>
      <strong><%= number_to_currency(@faturamento_previsto, unit: "R$ ", separator: ",", delimiter: ".") %></strong>
    </div>
  </section>

  <section class="data-panel">
    <div class="panel-header">
      <div>
        <h2>Ordens recentes</h2>
        <span class="muted-text"><%= @ordens_abertas_count %> em andamento ou aguardando atendimento</span>
      </div>
      <%= link_to ordem_servicos_path, class: "btn btn-sm btn-outline-secondary fw-bold" do %>
        <i class="bi bi-list-ul"></i> Ver todas
      <% end %>
    </div>

    <% if @ordens_recentes.any? %>
      <div class="table-responsive">
        <table class="table table-hover align-middle">
          <thead>
            <tr>
              <th>OS</th>
              <th>Cliente</th>
              <th>Veiculo</th>
              <th>Status</th>
              <th class="text-end">Valor</th>
            </tr>
          </thead>
          <tbody>
            <% @ordens_recentes.each do |ordem| %>
              <tr>
                <td class="fw-bold">#<%= ordem.id %></td>
                <td><%= ordem.cliente.name %></td>
                <td><span class="plate"><%= ordem.veiculo.placa %></span></td>
                <td><span class="badge <%= ordem.status_badge_class %>"><%= ordem.status %></span></td>
                <td class="text-end"><%= number_to_currency(ordem.valor, unit: "R$ ", separator: ",", delimiter: ".") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="empty-state">
        <i class="bi bi-clipboard-plus"></i>
        <strong>Nenhuma ordem cadastrada</strong>
        <p class="mb-0">Cadastre clientes, veiculos e crie a primeira ordem de servico.</p>
      </div>
    <% end %>
  </section>
</main>
