<% content_for :title, "#{@veiculo.placa} | Oficina Dois Irmaos" %>

<main class="page-shell">
  <section class="page-heading">
    <div>
      <p class="eyebrow">Ficha do veiculo</p>
      <h1><%= @veiculo.marca %> <%= @veiculo.modelo %></h1>
      <p><span class="plate"><%= @veiculo.placa %></span> <span class="ms-2">Proprietario: <%= link_to @veiculo.cliente.name, @veiculo.cliente, class: "link-dark fw-bold" %></span></p>
    </div>
    <div class="action-row">
      <%= link_to new_ordem_servico_path(veiculo_id: @veiculo.id), class: "btn btn-warning fw-bold" do %>
        <i class="bi bi-clipboard-plus"></i> Nova OS
      <% end %>
      <%= link_to edit_veiculo_path(@veiculo), class: "btn btn-outline-dark fw-bold" do %>
        <i class="bi bi-pencil-square"></i> Editar
      <% end %>
    </div>
  </section>

  <section class="detail-panel mb-4">
    <div class="detail-grid">
      <div class="detail-item">
        <span>Marca e modelo</span>
        <strong><%= @veiculo.marca %> <%= @veiculo.modelo %></strong>
      </div>
      <div class="detail-item">
        <span>Ano</span>
        <strong><%= @veiculo.ano %></strong>
      </div>
    </div>
  </section>

  <section class="data-panel">
    <div class="panel-header">
      <div>
        <h2>Historico de ordens</h2>
        <span class="muted-text"><%= @ordens.size %> registros vinculados</span>
      </div>
      <%= link_to veiculos_path, class: "btn btn-sm btn-outline-secondary fw-bold" do %>
        <i class="bi bi-arrow-left"></i> Voltar
      <% end %>
    </div>

    <% if @ordens.any? %>
      <div class="table-responsive">
        <table class="table table-hover align-middle">
          <thead>
            <tr>
              <th>OS</th>
              <th>Descricao</th>
              <th>Status</th>
              <th class="text-end">Valor</th>
              <th class="text-end">Acoes</th>
            </tr>
          </thead>
          <tbody>
            <% @ordens.each do |ordem| %>
              <tr>
                <td class="fw-bold">#<%= ordem.id %></td>
                <td><%= truncate(ordem.descricao, length: 70) %></td>
                <td><span class="badge <%= ordem.status_badge_class %>"><%= ordem.status %></span></td>
                <td class="text-end"><%= number_to_currency(ordem.valor, unit: "R$ ", separator: ",", delimiter: ".") %></td>
                <td class="text-end">
                  <%= link_to ordem, class: "btn btn-sm btn-outline-secondary" do %>
                    <i class="bi bi-eye"></i>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="empty-state">
        <i class="bi bi-clipboard2-plus"></i>
        <strong>Nenhuma ordem para este veiculo</strong>
      </div>
    <% end %>
  </section>
</main>
