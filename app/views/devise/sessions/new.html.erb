<% content_for :title, "Entrar | Oficina Dois Irmaos" %>

<main class="auth-wrap">
  <section class="auth-card">
    <div class="auth-logo">
      <span class="brand-icon"><i class="bi bi-wrench-adjustable"></i></span>
      <div>
        <h1 class="h4 fw-black mb-0">Oficina Dois Irmaos</h1>
        <span class="muted-text">Acesso administrativo</span>
      </div>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-3">
        <%= f.label :email, "Email", class: "form-label fw-bold" %>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-envelope"></i></span>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", required: true %>
        </div>
      </div>

      <div class="mb-3">
        <%= f.label :password, "Senha", class: "form-label fw-bold" %>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-lock"></i></span>
          <%= f.password_field :password, autocomplete: "current-password", class: "form-control", required: true %>
        </div>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-check mb-3">
          <%= f.check_box :remember_me, class: "form-check-input" %>
          <%= f.label :remember_me, "Manter conectado", class: "form-check-label" %>
        </div>
      <% end %>

      <%= f.submit "Entrar", class: "btn btn-warning fw-bold w-100 py-2" %>
    <% end %>

    <div class="mt-3">
      <%= render "devise/shared/links" %>
    </div>
  </section>
</main>
