<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <title><%= content_for(:title) || "Oficina Dois Irmaos" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Oficina Dois Irmaos">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <%= javascript_importmap_tags %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <%= yield :head %>
  </head>

  <body class="<%= user_signed_in? ? "app-body" : "auth-body" %>">
    <% if user_signed_in? %>
      <header class="app-header">
        <nav class="container-fluid app-nav">
          <%= link_to root_path, class: "brand-mark" do %>
            <span class="brand-icon"><i class="bi bi-wrench-adjustable"></i></span>
            <span>
              <strong>Oficina Dois Irmaos</strong>
              <small>Gestao administrativa</small>
            </span>
          <% end %>

          <div class="nav-links">
            <%= link_to root_path, class: "nav-pill #{'active' if current_page?(root_path)}" do %>
              <i class="bi bi-speedometer2"></i> Painel
            <% end %>
            <%= link_to clientes_path, class: "nav-pill #{'active' if controller_name == 'clientes'}" do %>
              <i class="bi bi-people"></i> Clientes
            <% end %>
            <%= link_to veiculos_path, class: "nav-pill #{'active' if controller_name == 'veiculos'}" do %>
              <i class="bi bi-car-front"></i> Veiculos
            <% end %>
            <%= link_to ordem_servicos_path, class: "nav-pill #{'active' if controller_name == 'ordem_servicos'}" do %>
              <i class="bi bi-clipboard2-check"></i> Ordens
            <% end %>
          </div>

          <div class="user-menu">
            <span class="user-email"><i class="bi bi-person-circle"></i> <%= current_user.email %></span>
            <%= button_to destroy_user_session_path, method: :delete, class: "icon-button", title: "Sair" do %>
              <i class="bi bi-box-arrow-right"></i>
            <% end %>
          </div>
        </nav>
      </header>
    <% end %>

    <% if notice.present? || alert.present? %>
      <div class="container-fluid flash-area">
        <% if notice.present? %>
          <div class="alert alert-success shadow-sm mb-2"><i class="bi bi-check-circle me-2"></i><%= notice %></div>
        <% end %>
        <% if alert.present? %>
          <div class="alert alert-danger shadow-sm mb-2"><i class="bi bi-exclamation-triangle me-2"></i><%= alert %></div>
        <% end %>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
