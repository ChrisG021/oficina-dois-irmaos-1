<div class="d-grid gap-2">
  <%- if controller_name != "sessions" %>
    <%= link_to "Entrar", new_session_path(resource_name), class: "btn btn-sm btn-outline-secondary" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != "registrations" %>
    <%= link_to "Criar usuario", new_registration_path(resource_name), class: "btn btn-sm btn-outline-secondary" %>
  <% end %>
</div>


